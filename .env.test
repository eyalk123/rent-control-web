# E2E test mode — loaded by `vite --mode test` (Playwright webServer).
# Runs the app fully offline against the in-memory mock data layer with auth bypassed.
# These vars are unset in normal dev/prod builds, so real Firebase + API behavior is unchanged.
VITE_USE_MOCK_API=true
VITE_E2E_AUTH_BYPASS=true
VITE_API_URL=http://localhost:8000
VITE_FIREBASE_API_KEY=test
VITE_FIREBASE_AUTH_DOMAIN=test
VITE_FIREBASE_PROJECT_ID=test
VITE_FIREBASE_APP_ID=test
